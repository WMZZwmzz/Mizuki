---
import type { PioConfig } from "@/types/config";
import { publicUrl } from "@/utils/url-utils";

interface Props {
	config: PioConfig;
}

const { config } = Astro.props;

const modelPaths = (config.models ?? [
	"/pio/models/NOIR/noir.model3.json",
]).map(publicUrl);
const modelConfigs = modelPaths.map((p) => ({ path: p }));

const position = config.position === "right" ? "bottom-right" : "bottom-left";

const tipsData: Record<string, unknown> = {};
if (config.tips) {
	if (config.tips.welcomeMessage)
		tipsData.welcomeMessage = config.tips.welcomeMessage;
	if (config.tips.messages) tipsData.messages = config.tips.messages;
	if (config.tips.duration) tipsData.duration = config.tips.duration;
	if (config.tips.interval) tipsData.interval = config.tips.interval;
} else if (config.dialog?.welcome || config.dialog?.touch) {
	const welcome = config.dialog.welcome;
	const touch = config.dialog.touch;
	if (welcome)
		tipsData.welcomeMessage = Array.isArray(welcome) ? welcome : [welcome];
	if (touch) tipsData.messages = Array.isArray(touch) ? touch : [touch];
}

const widgetConfig: Record<string, unknown> = {
	model: modelConfigs.length === 1 ? modelConfigs[0] : modelConfigs,
	position,
	size: config.width ?? 280,
	transitionDuration: 300,
	transitionType: "slide",
	_hideAbout: config.hideAboutMenu ?? true,
	// 让 iframe 内的拖拽逻辑感知模式：'fixed' 时禁用拖拽
	mode: config.mode ?? "draggable",
};

if (config.menus?.items && config.menus.items.length > 0) {
	widgetConfig.menus = {
		items: config.menus.items.map(({ icon, label, action }) => ({
			icon,
			label,
			action,
		})),
		...(config.menus.align && { align: config.menus.align }),
	};
}

if (Object.keys(tipsData).length > 0) {
	if (Array.isArray(widgetConfig.model)) {
		for (const m of widgetConfig.model) {
			(m as Record<string, unknown>).tips = tipsData;
		}
	} else {
		(widgetConfig.model as Record<string, unknown>).tips = tipsData;
	}
}

const widgetWidth = config.width ?? 280;
const widgetHeight = config.height ?? 600;
const isRight = config.position === "right";
const isDraggable = (config.mode ?? "draggable") !== "fixed";
const touchMessages = config.dialog?.touch ?? [];
const hiddenOnMobile = config.hiddenOnMobile ?? false;
---

<iframe
	id="l2d-iframe"
	data-role="pio-layer"
	data-src={publicUrl("/pio/live2d-host.html")}
	allowtransparency="true"
	style={"position: fixed; z-index: 999; pointer-events: none; border: none; bottom: 0;"
		+ (isRight ? " right: 0;" : " left: 0;")
		+ " width: " + widgetWidth + "px;"
		+ " height: " + widgetHeight + "px;"
		+ " opacity: 0;"}
	data-config={JSON.stringify(widgetConfig)}
	data-width={widgetWidth}
	data-is-right={isRight ? "true" : "false"}
	data-hidden-on-mobile={hiddenOnMobile ? "true" : "false"}
></iframe>

<!-- 交互代理层：覆盖 canvas 区域，捕获鼠标事件转发给 iframe -->
<div
	id="pio-interact-proxy"
	data-role="pio-layer"
	style={"position: fixed; z-index: 998; bottom: 0; pointer-events: none;"
		+ (isDraggable ? " cursor: grab;" : " cursor: pointer;")
		+ (isRight ? " right: 0;" : " left: 0;")
		+ " width: " + widgetWidth + "px;"
		+ " height: " + widgetHeight + "px;"}
></div>

<!-- 气泡容器 -->
<div
	id="pio-bubble-container"
	data-role="pio-layer"
	style={"position: fixed; z-index: 1000; bottom: 0; pointer-events: none;"
		+ (isRight ? " right: 0;" : " left: 0;")
		+ " width: " + widgetWidth + "px;"
		+ " height: " + widgetHeight + "px;"}
	data-messages={JSON.stringify(touchMessages)}
>
</div>

<script>
	type PioController = {
		update: (
			el: HTMLIFrameElement,
			config: Record<string, unknown>,
		) => void;
	};

	const win = window as Window & { __mizukiPioController?: PioController };
	const scriptEl = document.currentScript as HTMLScriptElement | null;
	const renderedEl =
		scriptEl?.previousElementSibling instanceof HTMLIFrameElement &&
		scriptEl.previousElementSibling.id === "l2d-iframe"
			? scriptEl.previousElementSibling
			: null;
	const frames = Array.from(
		document.querySelectorAll<HTMLIFrameElement>("#l2d-iframe"),
	);
	const el = frames[0] ?? renderedEl;
	const configSource = renderedEl ?? el;

	for (const frame of frames) {
		if (frame !== el) frame.remove();
	}

	// ── 移动端隐藏：屏幕宽度 <768px 时不加载 iframe、不渲染图层，避免 WebGL 性能开销 ──
	const mobileHidden =
		configSource?.dataset.hiddenOnMobile === "true" &&
		window.matchMedia("(max-width: 767px)").matches;
	if (mobileHidden) {
		document
			.querySelectorAll('[data-role="pio-layer"]')
			.forEach((n) => n.remove());
	}

	if (el && configSource && !mobileHidden) {
		// 桌面端：按需赋值 src 启动 iframe 加载（移动端跳过，避免触发 WebGL）
		if (el.dataset.src) el.src = el.dataset.src;
		const config = JSON.parse(configSource.dataset.config || "{}");

		if (!win.__mizukiPioController) {
			const menuActions: Record<string, () => void> = {
				home: () => (window.location.href = import.meta.env.BASE_URL),
				scrollToTop: () => window.scrollTo({ top: 0, behavior: "smooth" }),
			};

			let currentEl: HTMLIFrameElement | null = null;
			let currentConfig: Record<string, unknown> = {};
			let isTransitioning = false;
			let initSent = false;
			let currentConfigKey = "";
			let pendingInit: number | undefined;
			let swupHooksRegistered = false;
			let modelHeight = 0; // 模型实际高度，由 iframe l2d-loaded 上报，用于 Y 轴钳制

			// ── 气泡系统 ──
			const bubbleContainer = document.getElementById("pio-bubble-container");
			const bubbleMessages: string[] = bubbleContainer?.dataset.messages
				? JSON.parse(bubbleContainer.dataset.messages)
				: [];
			const msgs = bubbleMessages.length > 0 ? bubbleMessages : ["你好呀~"];

			// 注入动画
			const animStyle = document.createElement("style");
			animStyle.textContent =
				"@keyframes pio-in{from{opacity:0;transform:scale(.8)}to{opacity:1;transform:scale(1)}}" +
				"@keyframes pio-out{from{opacity:1;transform:scale(1)}to{opacity:0;transform:scale(.8)}}";
			document.head.appendChild(animStyle);

			const POSITIONS = [
				{ bottom: 340, left: "50%", tf: "translateX(-50%)" },
				{ bottom: 60, left: "50%", tf: "translateX(-50%)" },
				{ bottom: 200, left: "-10px", tf: "translateX(-100%)" },
				{ bottom: 200, left: "calc(100% + 10px)", tf: "none" },
			];

			function showBubble() {
				if (!bubbleContainer) return;

				const msg = msgs[Math.floor(Math.random() * msgs.length)];
				const pos = POSITIONS[Math.floor(Math.random() * POSITIONS.length)];

				const b = document.createElement("div");
				b.textContent = msg;
				Object.assign(b.style, {
					position: "absolute",
					bottom: pos.bottom + "px",
					left: pos.left,
					transform: pos.tf,
					background: "#4a9eff",
					color: "#fff",
					padding: "8px 14px",
					borderRadius: "12px",
					fontSize: "13px",
					lineHeight: "1.4",
					maxWidth: "200px",
					wordBreak: "break-word",
					whiteSpace: "normal",
					textAlign: "center",
					boxShadow: "0 2px 8px rgba(74,158,255,.3)",
					pointerEvents: "none",
					opacity: "0",
					zIndex: "1",
					animation: "pio-in .3s ease-out forwards",
				});
				bubbleContainer.appendChild(b);

				while (bubbleContainer.children.length > 6) {
					bubbleContainer.firstChild?.remove();
				}
				setTimeout(() => {
					b.style.animation = "pio-out .3s ease-in forwards";
					setTimeout(() => b.remove(), 300);
				}, 2500);
			}

			// ── 交互代理：转发鼠标事件给 iframe ──
				const proxy = document.getElementById("pio-interact-proxy");
				const bubbleContainerEl = document.getElementById(
					"pio-bubble-container",
				);
				// 是否可拖拽：从 iframe data-config 中读取 mode（'fixed' 时禁用拖拽）
				const layerConfig = config as Record<string, unknown>;
				const isDraggable = (layerConfig.mode ?? "draggable") !== "fixed";
				// 三层（iframe / proxy / bubble）需要整体跟随拖拽
				const layers = [el, proxy, bubbleContainerEl].filter(
					(x): x is HTMLElement | HTMLIFrameElement => !!x,
				);
				const layerWidth = Number(el?.dataset.width || 280);

				if (proxy && el) {
					let isDragging = false;
					let isHovering = false;
					// 累计 transform 偏移量（跨多次拖拽持久化）
					let dragTranslateX = 0;
					let dragTranslateY = 0;
					// 拖拽跟踪：父页面直接计算增量，无需 iframe 往返
					let dragStartX = 0;
					let dragStartY = 0;
					let dragLastX = 0;
					let dragLastY = 0;
					let dragMoved = false;

					const forwardEvent = (type: string, e: MouseEvent) => {
						// 传递 iframe 在父页面视口中的偏移，供 iframe 内部坐标转换使用
						const iframeRect = el.getBoundingClientRect();
						el.contentWindow?.postMessage(
							{ type: "l2d-mouse", event: type, x: e.clientX, y: e.clientY,
							  iframeX: iframeRect.left, iframeY: iframeRect.top },
							"*",
						);
					};

					// 拖拽时按增量同步三层位置（使用 transform，避免触发 layout 导致 iframe 内 WebGL 丢上下文）
					const applyDragDelta = (dx: number, dy: number) => {
						if (dx === 0 && dy === 0) return;
						// rect 已含当前 transform，直接拿来算新位置
						const rect = el.getBoundingClientRect();
						let newLeft = rect.left + dx;
						let newTop = rect.top + dy;
						// 钳制在视口内：需减去图层自身宽高，否则拖到底边时整个部件会移出视口而消失
						const maxX = window.innerWidth - layerWidth;
						const maxY = window.innerHeight - rect.height;
						// 模型在 iframe 底部，允许 iframe 顶部超出视口（minY 为负），向上拖拽范围 = innerHeight - modelHeight
						const minY = modelHeight - rect.height;
						newLeft = Math.max(0, Math.min(newLeft, maxX));
						newTop = Math.max(minY, Math.min(newTop, maxY));
						// 累计实际位移（含钳制修正），用 transform 避免触发 layout/resize
						dragTranslateX += newLeft - rect.left;
						dragTranslateY += newTop - rect.top;
						const transform = `translate(${dragTranslateX}px, ${dragTranslateY}px)`;
						for (const layer of layers) {
							layer.style.transform = transform;
						}
					};

					// ── 像素级透明检测：仅在不透明像素上捕获事件，透明区域点击穿透 ──
					// iframe 与父页面同源，可直接同步调用 iframe 内的 readPixels，
					// 从而让桌面端(mousemove)与移动端(合成 mousemove)都能在 mousedown 前确定 pointer-events。
					type L2DHostWindow = Window & {
						__l2dHitTest?: (
							x: number,
							y: number,
							iframeX: number,
							iframeY: number,
						) => boolean;
					};
					const hitTest = (e: { clientX: number; clientY: number }): boolean => {
						try {
							const host = el.contentWindow as L2DHostWindow | null;
							const fn = host?.__l2dHitTest;
							if (typeof fn !== "function") return true; // 未就绪：保持捕获，避免加载前误穿透
							const iframeRect = el.getBoundingClientRect();
							return !!fn(
								e.clientX,
								e.clientY,
								iframeRect.left,
								iframeRect.top,
							);
						} catch {
							return true;
						}
					};

					// 点击穿透兜底：临时关闭代理层 pointer-events，定位下方真实元素并派发完整点击序列
					const passThroughClick = (e: MouseEvent) => {
						const x = e.clientX;
						const y = e.clientY;
						const prev = proxy.style.pointerEvents;
						proxy.style.pointerEvents = "none";
						const target = document.elementFromPoint(x, y) as HTMLElement | null;
						proxy.style.pointerEvents = prev;
						if (!target || target === proxy || target === el) return;
						const down = new MouseEvent("mousedown", {
							bubbles: true, cancelable: true, view: window,
							clientX: x, clientY: y, button: 0, buttons: 1,
						});
						const up = new MouseEvent("mouseup", {
							bubbles: true, cancelable: true, view: window,
							clientX: x, clientY: y, button: 0, buttons: 0,
						});
						const click = new MouseEvent("click", {
							bubbles: true, cancelable: true, view: window,
							clientX: x, clientY: y, button: 0, buttons: 0,
						});
						target.dispatchEvent(down);
						target.dispatchEvent(up);
						target.dispatchEvent(click);
					};

					// mousemove 节流：降低 readPixels 的 GPU 同步开销（点击时不节流，实时判定）
					let lastHitTime = 0;
					let lastHitResult = true; // 默认不透明（捕获），避免加载前误穿透
					const HIT_THROTTLE = 40;
					const hitTestThrottled = (e: MouseEvent): boolean => {
						const now = performance.now();
						if (now - lastHitTime > HIT_THROTTLE) {
							lastHitTime = now;
							lastHitResult = hitTest(e);
						}
						return lastHitResult;
					};

					// 动态检测鼠标是否在代理区域内，按需启用 pointer-events
					// bounds 进入/离开 → 转发 mouseenter/mouseleave（控制 iframe 内按钮栏显隐）
					// bounds 内 → 按像素透明度切换 pointer-events（与按钮栏显隐解耦）
					const updateProxyState = (e: MouseEvent) => {
						if (isDragging) return;
						const rect = proxy.getBoundingClientRect();
						const inBounds =
							e.clientX >= rect.left && e.clientX <= rect.right &&
							e.clientY >= rect.top && e.clientY <= rect.bottom;

						if (inBounds && !isHovering) {
							isHovering = true;
							forwardEvent("mouseenter", e);
						} else if (!inBounds && isHovering) {
							isHovering = false;
							proxy.style.pointerEvents = "none";
							forwardEvent("mouseleave", e);
							return;
						}

						if (inBounds) {
							proxy.style.pointerEvents = hitTestThrottled(e) ? "auto" : "none";
						}
					};

					document.addEventListener("mousemove", (e) => {
						updateProxyState(e);
						if (isDragging) {
							// 父页面直接计算增量并应用 transform，消除 iframe postMessage 往返延迟
							const dx = e.clientX - dragLastX;
							const dy = e.clientY - dragLastY;
							dragLastX = e.clientX;
							dragLastY = e.clientY;
							if (Math.abs(e.clientX - dragStartX) > 5 || Math.abs(e.clientY - dragStartY) > 5) dragMoved = true;
							applyDragDelta(dx, dy);
						}
					}, { passive: true });

					// 移动端：在合成鼠标事件派发前，于 touchstart 同步确定 pointer-events，
					// 避免部分浏览器跳过合成 mousemove 导致 mousedown 落到错误目标。
					// passive 且不 preventDefault，不影响页面滚动。
					document.addEventListener("touchstart", (e) => {
						if (isDragging) return;
						const t = e.touches[0];
						if (!t) return;
						const rect = proxy.getBoundingClientRect();
						const inBounds =
							t.clientX >= rect.left && t.clientX <= rect.right &&
							t.clientY >= rect.top && t.clientY <= rect.bottom;
						if (!inBounds) return;
						const pe = hitTest(t) ? "auto" : "none";
						proxy.style.pointerEvents = pe;
						if (pe === "auto" && !isHovering) {
							isHovering = true;
							forwardEvent("mouseenter", new MouseEvent("mouseenter", { clientX: t.clientX, clientY: t.clientY }));
						}
					}, { passive: true, capture: true });

					proxy.addEventListener("mousedown", (e) => {
						isDragging = true;
						proxy.style.pointerEvents = "auto";
						if (isDraggable) proxy.style.cursor = "grabbing";
						dragStartX = dragLastX = e.clientX;
						dragStartY = dragLastY = e.clientY;
						dragMoved = false;
						forwardEvent("mousedown", e);
					});

					document.addEventListener("mouseup", (e) => {
						if (isDragging) {
							isDragging = false;
							proxy.style.cursor = isDraggable ? "grab" : "pointer";
							forwardEvent("mouseup", e);
							// 拖拽结束后按当前位置重新评估 pointer-events（避免停在透明区仍捕获）
							requestAnimationFrame(() => updateProxyState(e));
						}
					});

					proxy.addEventListener("click", (e) => {
						// 拖拽后吞掉一次 click，避免触发模型动作/气泡
						if (dragMoved) { dragMoved = false; return; }
						// 兜底：若透明区域仍捕获到 click（节流延迟/合成事件时序差异），则穿透到下方元素
						if (!hitTest(e)) {
							passThroughClick(e);
							return;
						}
						forwardEvent("click", e);
					});


				}

				// ── 原有逻辑 ──
			function applyVisibility() {
				if (!currentEl) return;
				currentEl.style.display = "";
			}

			function postInit() {
				if (!currentEl || initSent || isTransitioning) return;
				currentEl.contentWindow?.postMessage(
					{ type: "l2d-init", config: currentConfig },
					"*",
				);
				initSent = true;
			}

			function scheduleInit() {
				window.clearTimeout(pendingInit);
				const _window = window as Window & {
					requestIdleCallback?: (
						callback: IdleRequestCallback,
						options?: IdleRequestOptions,
					) => number;
				};
				const run = () => {
					pendingInit = window.setTimeout(postInit, 0);
				};
				if (_window.requestIdleCallback) {
					_window.requestIdleCallback(run, { timeout: 2000 });
				} else {
					pendingInit = window.setTimeout(postInit, 500);
				}
			}

			function handleMessage(e: MessageEvent) {
				if (!currentEl || e.source !== currentEl.contentWindow) return;

				if (e.data.type === "l2d-loaded") {
					const h = e.data.contentHeight || 500;
					currentEl.style.height = h + "px";
					currentEl.style.opacity = "1";
					modelHeight = e.data.modelHeight || h;
				}

				if (e.data.type === "l2d-action") {
					menuActions[e.data.action]?.();
				}

				if (e.data.type === "l2d-click") {
					showBubble();
				}
			}

			function setupSwupHooks() {
				const swup = window.swup;
				if (swupHooksRegistered || !swup?.hooks) return;
				swupHooksRegistered = true;

				swup.hooks.on("link:click", () => {
					isTransitioning = true;
				});

				swup.hooks.on("visit:end", () => {
					isTransitioning = false;
					scheduleInit();
				});
			}

			window.addEventListener("message", handleMessage);
			window.addEventListener("resize", () => {
				applyVisibility();
				scheduleInit();
			});

			if (window.swup) {
				setupSwupHooks();
			} else {
				document.addEventListener("swup:enable", setupSwupHooks, {
					once: true,
				});
			}

			// 欢迎气泡
			setTimeout(showBubble, 1500);

			win.__mizukiPioController = {
				update(nextEl, nextConfig) {
					const isNewFrame = currentEl !== nextEl;
					const nextConfigKey = JSON.stringify(nextConfig);
					currentEl = nextEl;
					currentConfig = nextConfig;
					if (isNewFrame || currentConfigKey !== nextConfigKey) {
						initSent = false;
						currentConfigKey = nextConfigKey;
					}
					if (isNewFrame) {
						nextEl.addEventListener("load", () => {
							initSent = false;
							scheduleInit();
						});
					}
					applyVisibility();
					if (nextEl.contentDocument?.readyState === "complete") {
						scheduleInit();
					}
				},
			};
		}

		win.__mizukiPioController.update(el, config);
	}
</script>
